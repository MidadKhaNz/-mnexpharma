# Normalize line endings
* text=auto

# Force LF for source files
*.vue text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md  text eol=lf

# Binary files — no diff/merge
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
